# =============================================
# DIJASPORA.BA — Environment varijable
# Kopiraj ovaj fajl u .env.local i popuni
# =============================================

# Supabase (nađi na supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Claude / Anthropic API (nađi na console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Cron secret — zaštita daily-content endpointa
# Generiraj slučajni string: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Admin panel lozinka — postavi što god hoćeš
ADMIN_SECRET=tvoja-admin-lozinka-ovdje

# App URL
NEXT_PUBLIC_SITE_URL=https://dijaspora.ba

# =============================================
# VERCEL setup (dodaj u Vercel dashboard pod Settings → Environment Variables)
# Isti ključevi kao gore, ali bez NEXT_PUBLIC_ za tajne varijable
# =============================================

# Koliko članaka bot napiše PO POKRETANJU, po kategoriji.
# Sa 2 pokretanja dnevno (08:00 i 20:00) = 2 po kategoriji = 6 ukupno dnevno.
CLANCI_DIJASPORA=1
CLANCI_SVIJET=1
CLANCI_SPORT=1

# Unsplash — naslovne slike članaka (samo URL, slike se ne čuvaju u bazi)
# Besplatan ključ: https://unsplash.com/developers → New Application → Access Key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
